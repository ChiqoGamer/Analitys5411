PORT=4000

# ID del Google Sheet: lo sacás de la URL
# https://docs.google.com/spreadsheets/d/ESTE_ES_EL_ID/edit
SHEET_ID=pega_aqui_el_id_del_google_sheet

# Rango a leer. Ajustar al nombre real de la pestaña y a las columnas usadas.
SHEET_RANGE=OrderHistory!A:AC

# Credenciales de la cuenta de servicio de Google.
# - DESARROLLO: no definas esta variable; se usa ./service-account.json (no versionado).
# - PRODUCCIÓN: pegá acá el JSON completo del service account en UNA sola línea.
#   Generarlo con:  GOOGLE_CREDENTIALS_JSON=$(cat service-account.json | tr -d '\n')
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"...", ...}
